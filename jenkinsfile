pipeline {
    agent any

    stages {
        stage('Checkout Source') {
            steps {
                git 'https://github.com/your-username/your-repo.git'  // Replace with your Git repo URL
            }
        }

        stage('Build Docker Image') {
            steps {
                script {
                    // Build Docker image with tag prt-nginx:latest
                    docker.build('prt-nginx:latest')
                }
            }
        }

        stage('Run Docker Container') {
            steps {
                script {
                    // Stop any existing container named prt-nginx
                    sh 'docker rm -f prt-nginx || true'
                    // Run new container on port 8080
                    docker.run('-d -p 8080:80 --name prt-nginx prt-nginx:latest')
                }
            }
        }
    }

    post {
        success {
            echo 'Pipeline completed successfully. Docker image is running!'
        }
        failure {
            echo 'Pipeline failed. Check the logs.'
        }
    }
}
